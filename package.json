{
  "name": "tripdesk",
  "version": "0.1.0",
  "description": "TripDesk — agent-native flight booking workbench (Cloudflare Workers + D1 + Durable Objects)",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "concurrently -n vite,worker -c blue,green \"vite\" \"wrangler dev\"",
    "rebyte:dev": "cp .dev.vars.dev .dev.vars && echo '.dev.vars -> DEV rebyte (127.0.0.1:34567, skills v3). restart: pnpm dev'",
    "rebyte:prod": "cp .dev.vars.prod .dev.vars && echo '.dev.vars -> PROD rebyte (api.rebyte.ai). restart: pnpm dev'",
    "build": "vite build",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply tripdesk --remote",
    "db:migrate:local": "wrangler d1 migrations apply tripdesk --local",
    "bootstrap:rebyte": "node --env-file=.env.local --import tsx scripts/bootstrap-rebyte.ts",
    "test": "node --import tsx --test worker/*.test.ts server/*.test.ts",
    "test:rebyte": "node --env-file=.env.local --import tsx server/rebyte/smoke.ts",
    "test:rebyte:multiturn": "node --env-file=.env.local --import tsx server/rebyte/multiturn.ts",
    "test:rebyte:config": "node --env-file=.env.local --import tsx server/rebyte/configprobe.ts",
    "test:rebyte:remove": "node --env-file=.env.local --import tsx server/rebyte/removeprobe.ts"
  },
  "dependencies": {
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "hono": "^4.12.10",
    "idb-keyval": "^6.2.5",
    "jose": "^6.2.3",
    "jotai": "^2.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rebyte-sandbox": "github:ReByteAI/sandbox-sdk#84b68495e0e958e75835336a59aa9f125dcca0d8",
    "remark-gfm": "^4.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250603.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.98.0"
  }
}
